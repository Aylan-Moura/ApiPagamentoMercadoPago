# Copie para .env e preencha TODOS os valores antes de rodar.
# Nunca commite o arquivo .env — ele está no .gitignore.

# ── Perfil ─────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Banco de dados (obrigatório) ───────────────────────────────────────────────
# Sem valores padrão — você DEVE definir antes de rodar a aplicação.
DATABASE_URL=jdbc:postgresql://localhost:5432/apipagamento_dev
DATABASE_USERNAME=           # Defina aqui (ex: postgres)
DATABASE_PASSWORD=           # Defina aqui — NUNCA use senhas triviais

# ── Mercado Pago (obrigatório) ────────────────────────────────────────────────
# Token de TESTE do painel: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx-substitua-aqui

# Obrigatório para webhooks em produção — URL pública da sua API
# Em dev local, deixe vazio para desativar webhooks
MERCADOPAGO_APP_BASE_URL=

# Obrigatório para validação de assinatura dos webhooks
# Obtido em: Suas integrações > Webhooks > Ver assinatura
MERCADOPAGO_WEBHOOK_SECRET=  # OBRIGATÓRIO em produção

# ── Frontend ───────────────────────────────────────────────────────────────────
APP_FRONTEND_URL=https://landing-pag-api-pagamentos.vercel.app

# ── CORS ───────────────────────────────────────────────────────────────────────
APP_CORS_ORIGINS=https://landing-pag-api-pagamentos.vercel.app,http://localhost:63342

# ── Produto ────────────────────────────────────────────────────────────────────
APP_PRODUCT_TITLE=Curso Completo de Backend
APP_PRODUCT_DESCRIPTION=Aprenda a criar APIs profissionais com banco de dados e pagamentos integrados
APP_PRODUCT_PRICE=99.90
